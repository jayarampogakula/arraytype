<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

</IfModule>

# ============================================================
# SECURITY HARDENING - ArrayType
# ============================================================

# --- Block access to sensitive files ---
<FilesMatch "(\.env|\.env\.example|composer\.json|composer\.lock|package\.json|package\-lock\.json|artisan|webpack\.mix\.js|vite\.config\.js|phpunit\.xml|\.gitignore|\.gitattributes)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# --- Block SQL Injection patterns ---
<IfModule mod_rewrite.c>
    RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete|update|create|alter|exec|execute|xp_|char|nchar|varchar|cast|convert|declare|script|javascript|vbscript|onload|onerror|onclick|expression|alert|confirm) [NC]
    RewriteRule .* - [F,L]

    # Block common attack paths
    RewriteCond %{REQUEST_URI} (wp-admin|wp-login|xmlrpc|phpmyadmin|adminer|shell|\.php\.bak|eval-stdin|\.git|\.svn|\.htpasswd) [NC]
    RewriteRule .* - [F,L]

    # Block access to hidden dot files (.git, .svn, etc.)
    RewriteCond %{REQUEST_URI} /\. [NC]
    RewriteRule .* - [F,L]

</IfModule>

# --- Security Response Headers ---
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always unset Server
    Header always unset X-Powered-By
    # Do not cache sensitive pages
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
</IfModule>

# --- Disable server signature ---
ServerSignature Off
